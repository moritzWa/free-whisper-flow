# Copy this file to .env and fill in your keys

# STT provider: "elevenlabs" (default), "deepgram", or "fluidaudio" (local, no API key needed)
STT_PROVIDER=elevenlabs

# API keys (only needed for cloud providers)
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# Optional: Groq API key for LLM transcript cleanup
GROQ_API_KEY=

# Hotkey to start/stop recording (default: cmd+shift+m)
# Examples: cmd+shift+m, ctrl+alt+r, cmd+shift+k
HOTKEY=cmd+shift+m
